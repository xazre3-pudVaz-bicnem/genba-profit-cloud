# ============================================================
# 現場収支クラウド 環境変数
# すべて未設定でもアプリはデモモードで完全動作します
# ============================================================

# --- アプリ名（あとでサービス名を変更する場合はここを変える）---
NEXT_PUBLIC_APP_NAME=現場収支クラウド

# ============================================================
# LP / アプリのURL分離（CTAリンクはすべてこの変数を経由する）
#
# 【現在: 単一プロジェクト運用】
#   未設定のままでOK（LP=/ 、アプリ=/app、認証=/login /signup）
#
# 【開発中に明示する場合の例】
#   NEXT_PUBLIC_MARKETING_URL=http://localhost:3000
#   NEXT_PUBLIC_APP_URL=http://localhost:3000/app
#
# 【将来: 別ドメイン分離後の例】
#   NEXT_PUBLIC_MARKETING_URL=https://genba-profit-cloud.jp
#   NEXT_PUBLIC_APP_URL=https://app.genba-profit-cloud.jp
# ============================================================
NEXT_PUBLIC_MARKETING_URL=
NEXT_PUBLIC_APP_URL=

# --- Supabase（未設定の場合はデモモード：ブラウザ内保存で動作）---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- AI OCR（どちらか一方でOK。両方未設定ならモック解析で動作）---
# 第一候補: Claude Vision API
ANTHROPIC_API_KEY=
# OCRに使うモデル（省略時: claude-opus-4-8。コスト重視なら claude-haiku-4-5 に変更可）
OCR_MODEL=

# 第二候補: OpenAI Vision API
OPENAI_API_KEY=
