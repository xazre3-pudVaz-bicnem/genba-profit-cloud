# ============================================================
# 現場収支クラウド 環境変数
# すべて未設定でもアプリはデモモードで完全動作します
# ============================================================

# --- アプリ名（あとでサービス名を変更する場合はここを変える）---
NEXT_PUBLIC_APP_NAME=現場収支クラウド

# --- 本番URL（SEO/OGP用。未設定時は http://localhost:3000）---
NEXT_PUBLIC_SITE_URL=https://example.com

# --- Supabase（未設定の場合はデモモード：ブラウザ内保存で動作）---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- AI OCR（どちらか一方でOK。両方未設定ならモック解析で動作）---
# 第一候補: Claude Vision API
ANTHROPIC_API_KEY=
# OCRに使うモデル（省略時: claude-opus-4-8。コスト重視なら claude-haiku-4-5 に変更可）
OCR_MODEL=

# 第二候補: OpenAI Vision API
OPENAI_API_KEY=
